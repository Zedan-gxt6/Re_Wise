<%- include('partials/header') %>

<%
    const isSolving = Boolean(locals.solveMode);
    const solve = locals.solveData || {};
    const isManualSolve = isSolving && solve.mode === "manual";
    const isKnownSolve = isSolving && solve.mode === "known";
    const pageTitle = isKnownSolve
        ? `Solving: ${solve.title}`
        : isManualSolve
            ? "Solving: Unsupported Problem"
            : "Add a New DSA Problem";
%>

<h1 class="<%= isSolving ? 'solve-title' : '' %>"><%= pageTitle %></h1>
<p>
    <%= isSolving
        ? "Track your solve details while the problem metadata stays ready in the background."
        : "Log a new problem you've recently solved or want to track."
    %>
</p>

<% if (isSolving && solve.url) { %>
    <div class="solve-source-actions">
        <a href="<%= solve.url %>" target="_blank" class="btn btn-solve">Go to problem</a>
    </div>
<% } %>

<% if (isKnownSolve && locals.followedCards && followedCards.length > 0) { %>
    <section class="social-solve-section">
        <div class="social-section-heading">
            <div>
                <span>From Your Circle</span>
                <h2>People you follow solved this</h2>
            </div>
            <p><%= followedCards.length %> visible card<%= followedCards.length === 1 ? '' : 's' %></p>
        </div>

        <div class="social-card-grid">
            <% followedCards.forEach((card) => { %>
                <details class="social-problem-card compact-social-card">
                    <summary class="social-person-summary">
                        <div class="mini-avatar">
                            <% if (card.profile_pic_url) { %>
                                <img src="<%= card.profile_pic_url %>" alt="<%= card.username %> profile photo">
                            <% } else { %>
                                <span><%= card.username.slice(0, 1).toUpperCase() %></span>
                            <% } %>
                        </div>
                        <div>
                            <h3><%= card.username %></h3>
                            <p>Solved this problem</p>
                        </div>
                    </summary>

                    <div class="social-card-expanded">
                        <div class="social-card-meta">
                            <span>Took <%= Math.round((card.time || 0) / 60) %> min</span>
                            <span>Level <%= card.rating %></span>
                        </div>

                        <details class="hint-details">
                            <summary>View notes</summary>
                            <div class="note-block">
                                <% if (card.code) { %>
                                    <p><strong>Approach:</strong></p>
                                    <pre class="social-approach"><code><%= card.code %></code></pre>
                                <% } %>
                                <% if (card.mistake_made) { %><p><strong>Mistake:</strong> <%= card.mistake_made %></p><% } %>
                                <% if (card.hardest_part) { %><p><strong>Hardest part:</strong> <%= card.hardest_part %></p><% } %>
                                <% if (card.hint_1) { %><p><strong>Hint 1:</strong> <%= card.hint_1 %></p><% } %>
                                <% if (card.hint_2) { %><p><strong>Hint 2:</strong> <%= card.hint_2 %></p><% } %>
                                <% if (card.hint_3) { %><p><strong>Hint 3:</strong> <%= card.hint_3 %></p><% } %>
                                <% if (!card.code && !card.mistake_made && !card.hardest_part && !card.hint_1 && !card.hint_2 && !card.hint_3) { %>
                                    <p>No notes shared for this card.</p>
                                <% } %>
                            </div>
                        </details>

                        <div class="social-card-actions">
                            <form action="/problem-cards/<%= card.id %>/like" method="POST" class="social-like-form">
                                <button type="submit" class="btn btn-secondary btn-sm">
                                    <span class="like-label"><%= card.liked_by_me ? 'Liked' : 'Like' %></span>
                                </button>
                            </form>
                        </div>

                        <form action="/problem-cards/<%= card.id %>/comments" method="POST" class="inline-comment-form">
                            <input type="text" name="comment" placeholder="Add a quick comment..." required>
                            <button type="submit" class="review-plus-button" aria-label="Post comment">
                                <span>+</span>
                            </button>
                        </form>
                        <div class="inline-comment-feedback"></div>
                    </div>
                </details>
            <% }) %>
        </div>
    </section>
<% } else if (isKnownSolve) { %>
    <section class="social-empty-card">
        No one you follow has shared this problem card yet.
    </section>
<% } %>

<form action="<%= isManualSolve ? '/add/manual' : '/add' %>" method="POST" class="add-problem-form">

    <% if (isSolving) { %>
        <input type="hidden" id="url" name="url" value="<%= solve.url || '' %>">
    <% } else { %>
       <div class="form-group">
            <label for="url">Problem URL:</label>
            <input
                type="url"
                id="url"
                name="url"
                required
                placeholder="https://leetcode.com/problems/..."
                value="<%= solve.url || '' %>"
            >
        </div>
    <% } %>

    <% if (isKnownSolve) { %>
        <section class="solve-meta-card">
            <div class="form-group">
                <label for="topic_override">Auto detected topic</label>
                <select id="topic_override" name="topic_override" required>
                    <% topics.forEach((topic) => { %>
                        <option value="<%= topic.id %>" <%= parseInt(solve.topic, 10) === topic.id ? 'selected' : '' %>>
                            <%= topic.name %>
                        </option>
                    <% }) %>
                </select>
            </div>
        </section>
    <% } %>

    <% if (isManualSolve) { %>
        <section class="solve-meta-card manual-solve-card">
            <p class="metadata-note"><%= solve.reason %></p>

            <input type="hidden" name="solve_form" value="1">
            <input type="hidden" name="slug" value="<%= solve.slug || '' %>">

            <div class="form-group">
                <label for="title">Problem title</label>
                <input
                    type="text"
                    id="title"
                    name="title"
                    required
                    value="<%= solve.title || '' %>"
                    placeholder="Exact title on the platform"
                >
            </div>

            <div class="form-group">
                <label for="platform">Platform</label>
                <input
                    type="text"
                    id="platform"
                    name="platform"
                    required
                    value="<%= solve.platform || 'other' %>"
                    placeholder="leetcode / neetcode250 / gfg / codechef / other"
                >
            </div>

            <div class="form-group">
                <label for="difficulty">Difficulty on platform</label>
                <select id="difficulty" name="difficulty" required>
                    <option value="" disabled <%= !solve.difficulty ? 'selected' : '' %>>Select difficulty</option>
                    <% ["Easy", "Medium", "Hard"].forEach((difficulty) => { %>
                        <option value="<%= difficulty %>" <%= solve.difficulty === difficulty ? 'selected' : '' %>>
                            <%= difficulty %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <div class="form-group">
                <label for="topic">Topic</label>
                <select id="topic" name="topic" required>
                    <option value="" disabled <%= !solve.topic ? 'selected' : '' %>>Choose topic</option>
                    <% topics.forEach((topic) => { %>
                        <option value="<%= topic.id %>" <%= parseInt(solve.topic, 10) === topic.id ? 'selected' : '' %>>
                            <%= topic.name %>
                        </option>
                    <% }) %>
                </select>
            </div>
        </section>
    <% } %>

    <!-- TIMER SECTION -->
    <div class="form-group">
        <label>Time Taken</label>

        <div
            id="timerDisplay"
            style="
                font-size: 24px;
                font-weight: bold;
                margin-top: 8px;
                margin-bottom: 10px;
            "
        >
            00:00
        </div>

        <div class="timer-actions">
            <button type="button" id="startTimerBtn" class="btn btn-secondary btn-sm">
                Start Timer
            </button>

            <button type="button" id="stopTimerBtn" class="btn btn-secondary btn-sm" disabled>
                Stop Timer
            </button>

            <button type="button" id="resetTimerBtn" class="btn btn-secondary btn-sm">
                Reset
            </button>
        </div>

        <div class="timer-adjust-row">
            <button type="button" class="btn btn-time-adjust btn-sm" data-adjust="-300">-5 min</button>
            <button type="button" class="btn btn-time-adjust btn-sm" data-adjust="-60">-1 min</button>
            <button type="button" class="btn btn-time-adjust btn-sm" data-adjust="60">+1 min</button>
            <button type="button" class="btn btn-time-adjust btn-sm" data-adjust="300">+5 min</button>
        </div>

        <label class="time-toggle-card" for="ignoreTime">
            <input type="checkbox" id="ignoreTime" name="ignore_time">
            <span>
                <strong>Don't consider time</strong>
                <small>Use expected time automatically based on difficulty.</small>
            </span>
        </label>

        <!-- Hidden field submitted to backend -->
        <input
            type="hidden"
            id="time"
            name="time"
            value="0"
        >
    </div>

    <div class="form-group">
        <label for="rating">Independence level | Struggle level | How likely are you to forget this problem approach: </label>
        <select id="rating" name="rating" required>
            <option value="" disabled selected>Select according to your parameter</option>
            <option value="1">Fully Independent | Solved easily | I'll remember longer</option>
            <option value="2">Took minor hints | Struggled a bit | I may forget</option>
            <option value="3">Major Hints Taken | Couldnt Solve | Very likely to forget</option>
        </select>
    </div>

    <div class="visibility-panel">
        <label for="visibility">Who can see this problem card?</label>
        <select id="visibility" name="visibility" required>
            <option value="public" selected>Public to followers</option>
            <option value="private">Private only me</option>
        </select>
        <small>Even public cards are only visible to people who follow you.</small>
    </div>

    <details class="optional-problem-details">
        <summary>Optional problem notes</summary>
        <div class="optional-notes-grid">
            <div class="form-group">
                <label for="code">Problem approach/insights</label>
                <textarea
                    id="code"
                    name="code"
                    rows="10"
                    placeholder="Paste your approach, pattern, or implementation insight here..."
                ></textarea>
            </div>

            <div class="form-group">
                <label for="mistake_made">Mistake made</label>
                <input type="text" id="mistake_made" name="mistake_made" placeholder="Example: used set instead of map">
            </div>

            <div class="form-group">
                <label for="hardest_part">Hardest part</label>
                <input type="text" id="hardest_part" name="hardest_part" placeholder="Example: realizing hash map was needed">
            </div>

            <details class="hint-details optional-hints">
                <summary>Add gradual hints</summary>
                <div class="optional-hints-body">
                    <div class="form-group">
                        <label for="hint_1">Hint 1</label>
                        <input type="text" id="hint_1" name="hint_1" placeholder="Small direction only">
                    </div>
                    <div class="form-group">
                        <label for="hint_2">Hint 2</label>
                        <input type="text" id="hint_2" name="hint_2" placeholder="Stronger nudge">
                    </div>
                    <div class="form-group">
                        <label for="hint_3">Hint 3</label>
                        <input type="text" id="hint_3" name="hint_3" placeholder="Almost reveals approach">
                    </div>
                </div>
            </details>
        </div>
    </details>

    <div class="submit-actions">
        <button type="submit" name="action" value="schedule" class="btn btn-schedule">
            Schedule Problem <span>Recommended</span>
        </button>

        <button type="submit" name="action" value="mastered" class="btn btn-mastered">
           Fix Problem <span>Mastered</span>
        </button>
    </div>

</form>

<script>
    const SOLVE_MODE = <%- JSON.stringify(isSolving) %>;
    const DRAFT_KEY = `rewise:add-problem-draft:${SOLVE_MODE ? window.location.href : 'new'}`;
    let timerInterval = null;
    let seconds = 0;
    let startTime;
    let sessionChecked = false;
    const MAX_TIMER_SECONDS = 90 * 60;

    const timerDisplay = document.getElementById('timerDisplay');
    const startBtn = document.getElementById('startTimerBtn');
    const stopBtn = document.getElementById('stopTimerBtn');
    const resetBtn = document.getElementById('resetTimerBtn');
    const timeTakenInput = document.getElementById('time');
    const form = document.querySelector('.add-problem-form');
    const urlInput = document.getElementById('url');
    const ratingInput = document.getElementById('rating');
    const visibilityInput = document.getElementById('visibility');
    const codeInput = document.getElementById('code');
    const ignoreTimeInput = document.getElementById('ignoreTime');
    const adjustButtons = document.querySelectorAll('[data-adjust]');
    const metadataInputs = document.querySelectorAll(
        '#title, #platform, #difficulty, #topic, #topic_override'
    );
    const optionalNoteInputs = document.querySelectorAll(
        '#mistake_made, #hardest_part, #hint_1, #hint_2, #hint_3'
    );

    function formatTime(totalSeconds) {
        const minutes = String(
            Math.floor(totalSeconds / 60)
        ).padStart(2, '0');

        const secs = String(
            totalSeconds % 60
        ).padStart(2, '0');

        return `${minutes}:${secs}`;
    }

    function updateTimer() {
        timerDisplay.textContent = formatTime(seconds);

        // Store raw seconds in hidden input
        timeTakenInput.value = seconds;
        saveDraft();
    }

    function saveDraft() {
        const draft = {
            url: urlInput.value,
            rating: ratingInput.value,
            visibility: visibilityInput.value,
            code: codeInput.value,
            seconds,
            ignoreTime: ignoreTimeInput.checked,
            metadata: Object.fromEntries(
                Array.from(metadataInputs).map((input) => [input.name, input.value])
            ),
            optionalNotes: Object.fromEntries(
                Array.from(optionalNoteInputs).map((input) => [input.name, input.value])
            ),
            savedAt: Date.now()
        };

        localStorage.setItem(DRAFT_KEY, JSON.stringify(draft));
    }

    function restoreDraft() {
        const rawDraft = localStorage.getItem(DRAFT_KEY);
        if (!rawDraft) return;

        try {
            const draft = JSON.parse(rawDraft);

            if (!SOLVE_MODE) {
                urlInput.value = draft.url || '';
            }
            ratingInput.value = draft.rating || '';
            visibilityInput.value = draft.visibility || 'public';
            codeInput.value = draft.code || '';
            ignoreTimeInput.checked = Boolean(draft.ignoreTime);
            Object.entries(draft.metadata || {}).forEach(([name, value]) => {
                const input = document.querySelector(`[name="${name}"]`);
                if (input) input.value = value || '';
            });
            Object.entries(draft.optionalNotes || {}).forEach(([name, value]) => {
                const input = document.querySelector(`[name="${name}"]`);
                if (input) input.value = value || '';
            });
            seconds = parseInt(draft.seconds, 10) || 0;
            updateTimer();
        } catch {
            localStorage.removeItem(DRAFT_KEY);
        }
    }

    startBtn.addEventListener('click', () => {

        if (timerInterval) return;

        startBtn.disabled = true;
        stopBtn.disabled = false;

        startTime = Date.now() - seconds * 1000;

        timerInterval = setInterval(() => {

            seconds = Math.floor(
                (Date.now() - startTime) / 1000
            );

            if (seconds > MAX_TIMER_SECONDS) {
                seconds = MAX_TIMER_SECONDS;
            }

            updateTimer();

            if (seconds >= MAX_TIMER_SECONDS) {
                clearInterval(timerInterval);
                timerInterval = null;
                startBtn.disabled = true;
                stopBtn.disabled = true;
            }

        }, 250);
    });

    stopBtn.addEventListener('click', () => {

        clearInterval(timerInterval);
        timerInterval = null;

        startBtn.disabled = false;
        stopBtn.disabled = true;
    });

    resetBtn.addEventListener('click', () => {

        clearInterval(timerInterval);
        timerInterval = null;

        seconds = 0;

        startBtn.disabled = false;
        stopBtn.disabled = true;

        updateTimer();
    });

    adjustButtons.forEach((button) => {
        button.addEventListener('click', () => {
            const change = parseInt(button.dataset.adjust, 10) || 0;
            seconds = Math.min(Math.max(seconds + change, 0), MAX_TIMER_SECONDS);

            if (timerInterval) {
                startTime = Date.now() - seconds * 1000;
            }

            updateTimer();
        });
    });

    [urlInput, ratingInput, visibilityInput, codeInput, ignoreTimeInput, ...metadataInputs, ...optionalNoteInputs].forEach((input) => {
        input.addEventListener('input', saveDraft);
        input.addEventListener('change', saveDraft);
    });

    restoreDraft();
    updateTimer();

    form.addEventListener('submit', async (event) => {
        if (sessionChecked) {
            localStorage.removeItem(DRAFT_KEY);
            return;
        }

        event.preventDefault();

        if (!ignoreTimeInput.checked && parseInt(timeTakenInput.value, 10) <= 0) {
            alert('Please start the timer and record time before adding the problem.');
            saveDraft();
            return;
        }

        saveDraft();

        try {
            const response = await fetch('/api/session');
            const data = await response.json();

            if (!data.authenticated) {
                alert('Your login expired. I saved this problem draft. Login once and you will come back here.');
                const returnTo = `${window.location.pathname}${window.location.search}`;
                window.location.href = `/login?returnTo=${encodeURIComponent(returnTo)}`;
                return;
            }

            sessionChecked = true;
            form.requestSubmit(event.submitter);
        } catch {
            alert('Could not verify your login. Your draft is saved, please try again.');
        }
    });

    document.querySelectorAll('.social-like-form').forEach((likeForm) => {
        likeForm.addEventListener('submit', async (event) => {
            event.preventDefault();

            const button = likeForm.querySelector('button');
            const label = likeForm.querySelector('.like-label');

            button.disabled = true;

            try {
                const response = await fetch(likeForm.action, {
                    method: 'POST',
                    headers: { Accept: 'application/json' }
                });

                if (!response.ok) throw new Error('Like failed');

                const data = await response.json();
                label.textContent = data.liked ? 'Liked' : 'Like';
            } catch {
                likeForm.submit();
            } finally {
                button.disabled = false;
            }
        });
    });

    document.querySelectorAll('.inline-comment-form').forEach((commentForm) => {
        commentForm.addEventListener('submit', async (event) => {
            event.preventDefault();

            const input = commentForm.querySelector('input[name="comment"]');
            const button = commentForm.querySelector('button');
            const card = commentForm.closest('.social-problem-card');
            const feedback = card.querySelector('.inline-comment-feedback');

            button.disabled = true;

            try {
                const response = await fetch(commentForm.action, {
                    method: 'POST',
                    headers: {
                        Accept: 'application/json',
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: new URLSearchParams(new FormData(commentForm))
                });

                if (!response.ok) throw new Error('Comment failed');

                input.value = '';
                feedback.textContent = 'Comment posted';
            } catch {
                feedback.textContent = 'Could not post comment. Try again.';
            } finally {
                button.disabled = false;
            }
        });
    });
</script>

<%- include('partials/footer') %>

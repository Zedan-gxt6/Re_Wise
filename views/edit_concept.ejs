<%- include('partials/header') %>

<div class="wide-editor-page">
<h1 class="txt-center">Edit Concept</h1>

<form action="/concepts/<%= concept.id %>/update" method="POST" class="form-group">
  <div class="form-group">
    <label for="title">Title</label>
    <input type="text" id="title" name="title" value="<%= concept.title %>" required>
  </div>

  <div class="form-group">
    <label for="book_id">Book</label>
    <select id="book_id" name="book_id">
      <option value="">No book / choose new book below</option>
      <% books.forEach(book => { %>
        <option value="<%= book.id %>" <%= concept.book_id === book.id ? 'selected' : '' %>>
          <%= book.name %>
        </option>
      <% }) %>
    </select>
  </div>

  <div class="form-group">
    <label for="new_book_name">Or Create New Book</label>
    <input type="text" id="new_book_name" name="new_book_name" placeholder="Leave blank to use selected book">
  </div>

  <div class="form-group">
    <label for="priority">Importance</label>
    <select id="priority" name="priority" required>
      <% [1, 2, 3, 4, 5].forEach(level => { %>
        <option value="<%= level %>" <%= (concept.priority || 3) === level ? 'selected' : '' %>>
          <%= level %><%= level === 5 ? ' - Extremely Important' : '' %>
        </option>
      <% }) %>
    </select>
  </div>

  <div class="form-group">
    <label for="concept">Concept</label>
    <textarea id="concept" name="concept" rows="15" class="large-code-textarea" required><%= concept.concept %></textarea>
  </div>

  <div class="form-group">
    <label for="review_days">Review Days</label>
    <input type="number" id="review_days" name="review_days" min="1" value="<%= concept.review_days || 1 %>" required>
  </div>

  <div class="submit-actions">
    <button type="submit" class="btn btn-schedule">Save Changes</button>
    <a href="/concepts/all" class="btn btn-secondary">Cancel</a>
  </div>
</form>
</div>

<%- include('partials/footer') %>

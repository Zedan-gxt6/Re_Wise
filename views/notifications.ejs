<%- include('partials/header') %>

<section class="social-page-header">
    <div>
        <span>Activity</span>
        <h1>Notifications</h1>
    </div>
    <% if (notifications.length > 0) { %>
        <form action="/notifications/clear" method="POST">
            <button type="submit" class="btn btn-secondary">Clear notifications</button>
        </form>
    <% } %>
</section>

<div class="notification-list">
    <% if (notifications.length === 0) { %>
        <div class="social-empty-card">No notifications yet.</div>
    <% } else { %>
        <% notifications.forEach((notification) => { %>
            <article class="notification-card <%= notification.is_read ? '' : 'notification-unread' %>">
                <div class="mini-avatar">
                    <% if (notification.actor_profile_pic_url) { %>
                        <img src="<%= notification.actor_profile_pic_url %>" alt="<%= notification.actor_username || 'User' %> profile photo">
                    <% } else { %>
                        <span><%= (notification.actor_username || 'R').slice(0, 1).toUpperCase() %></span>
                    <% } %>
                </div>

                <div class="notification-main">
                    <p><%= notification.message %></p>
                    <small><%= new Date(notification.created_at).toLocaleString() %></small>
                </div>

                <div class="notification-actions">
                    <% if (notification.type === 'follow_request') { %>
                        <form action="/notifications/<%= notification.id %>/follow-response" method="POST">
                            <button type="submit" name="action" value="accept" class="btn btn-mastered btn-sm">Accept</button>
                        </form>
                        <form action="/notifications/<%= notification.id %>/follow-response" method="POST">
                            <button type="submit" name="action" value="reject" class="btn btn-secondary btn-sm">Reject</button>
                        </form>
                    <% } else if (notification.type === 'followed_user_solved_problem' && notification.target_url) { %>
                        <a href="<%= notification.target_url %>" class="btn <%= notification.type === 'followed_user_solved_problem' ? 'btn-solve' : 'btn-secondary' %> btn-sm">
                            Solve Now
                        </a>
                    <% } %>
                </div>
            </article>
        <% }) %>
    <% } %>
</div>

<%- include('partials/footer') %>

<%- include('partials/header') %>

<%
function formatTime(seconds) {
    if (seconds === null || seconds === undefined) return 'N/A';
    const minutes = Math.floor(seconds / 60);
    const secs = seconds % 60;
    return `${minutes} min ${secs} sec`;
}

function maxRevisions(difficulty) {
    if (difficulty === 'Easy') return 3;
    if (difficulty === 'Medium') return 5;
    if (difficulty === 'Hard') return 7;
    return 5;
}

function hasNotes(problem) {
    return Boolean(
        problem.code ||
        problem.mistake_made ||
        problem.hardest_part ||
        problem.hint_1 ||
        problem.hint_2 ||
        problem.hint_3
    );
}
%>

<h1><%= title %> <span class="count-badge"><%= problems.length %></span></h1>

<div class="page-actions">
    <a href="/" class="btn btn-secondary">Back to Dashboard</a>
    <% if (problems.length > 0) { %>
        <a href="/problems/<%= difficulty %>/random" target="_blank" class="btn btn-info">🎲 Choose Random Problem</a>
    <% } %>
</div>

<% if (problems.length === 0) { %>
    <p>No problems found in this category.</p>
<% } else { %>
    <div class="problem-list">
        <% problems.forEach(problem => { %>
            <div class="problem-card">
                <h3><%= problem.title %> <% if (problem.status === 'MASTERED') { %> <span class="mastered-badge">Mastered 🎉</span> <% } %></h3>
                <% if (problem.url) { %>
                    <p><strong>URL:</strong> <a href="<%= problem.url %>" target="_blank"><%= problem.url %></a></p>
                <% } else { %>
                    <p><strong>URL:</strong> Not mapped yet</p>
                <% } %>
                <% if (problem.problem_difficulty) { %>
                    <p><strong>Difficulty:</strong> <%= problem.problem_difficulty %></p>
                <% } %>
                <p><strong>Independence:</strong> 
                    <% if (problem.rating === 1) { %> Fully Independent <% } %>
                    <% if (problem.rating === 2) { %> Minor Hints Taken <% } %>
                    <% if (problem.rating === 3) { %> Major Hints Taken/Couldn't Solve <% } %>
                </p>
                <p><strong>Time Taken:</strong> <%= formatTime(problem.time) %></p>
                <% if (problem.due_date) { %>
                    <p><strong>Due Date:</strong> <%= new Date(problem.due_date).toLocaleDateString() %></p>
                <% } %>
                <% if (problem.problem_difficulty) { %>
                    <p><strong>Revisions:</strong> <%= problem.revisions_done || 0 %> / <%= maxRevisions(problem.problem_difficulty) %></p>
                <% } %>
                <details class="hint-details">
                    <summary>View Topic</summary>
                    <div class="topic-reveal">
                        <%= problem.topic_name || 'No topic mapped yet' %>
                    </div>
                </details>
                <details class="hint-details">
                    <summary>View Notes</summary>
                    <div class="note-block">
                        <% if (problem.code) { %>
                            <p><strong>Problem approach/insights:</strong></p>
                            <pre><code><%= problem.code %></code></pre>
                        <% } %>
                        <% if (problem.mistake_made) { %>
                            <p><strong>Mistake made:</strong> <%= problem.mistake_made %></p>
                        <% } %>
                        <% if (problem.hardest_part) { %>
                            <p><strong>Hardest part:</strong> <%= problem.hardest_part %></p>
                        <% } %>
                        <% if (problem.hint_1) { %><p><strong>Hint 1:</strong> <%= problem.hint_1 %></p><% } %>
                        <% if (problem.hint_2) { %><p><strong>Hint 2:</strong> <%= problem.hint_2 %></p><% } %>
                        <% if (problem.hint_3) { %><p><strong>Hint 3:</strong> <%= problem.hint_3 %></p><% } %>
                        <% if (!hasNotes(problem)) { %>
                            <p>No notes added yet.</p>
                        <% } %>
                    </div>
                </details>
                <div class="actions-row">
                    <% if (problem.url) { %>
                        <a href="/solve?url=<%= encodeURIComponent(problem.url) %>" class="btn btn-solve btn-sm">Resolve</a>
                    <% } %>
                    <a href="/problems/<%= difficulty %>/<%= problem.id %>/edit" class="btn btn-action-schedule btn-sm">Edit Info</a>
                    <% if (difficulty === 'due') { %>
                        <form action="/problems/<%= difficulty %>/<%= problem.id %>/master" method="POST">
                            <button type="submit" class="btn btn-action-fix btn-sm">Fix (Mastered)</button>
                        </form>
                        <form action="/problems/<%= difficulty %>/<%= problem.id %>/revise" method="POST">
                            <select name="feedback" required>
                                <option value="remembered">Fully Remembered</option>
                                <option value="partial">Partially Forgot</option>
                                <option value="forgot">Couldn't Recall Approach</option>
                            </select>
                            <button type="submit" class="btn btn-action-revision btn-sm">Schedule Again</button>
                        </form>
                    <% } else { %>
                        <% if (problem.status !== 'MASTERED') { %>
                            <form action="/problems/<%= difficulty %>/<%= problem.id %>/master" method="POST">
                                <button type="submit" class="btn btn-action-fix btn-sm">Fix (Mastered)</button>
                            </form>
                        <% } else { %>
                            <form action="/problems/<%= difficulty %>/<%= problem.id %>/schedule" method="POST">
                                <button type="submit" class="btn btn-action-schedule btn-sm">Schedule</button>
                            </form>
                        <% } %>
                    <% } %>
                </div>
            </div>
        <% }) %>
    </div>
<% } %>

<%- include('partials/footer') %>

<%- include('partials/header') %>

<h1 style="text-align: center; margin-bottom: 1.5rem;">Welcome to Your Re_Wise Dashboard</h1>

<div class="stats-container" style="display: flex; gap: 1.5rem; justify-content: center; margin-bottom: 2rem; flex-wrap: wrap;">
    <div class="stat-card" style="background: var(--card-bg); border: 1px solid var(--border-color); padding: 1.25rem 2rem; border-radius: 12px; text-align: center; min-width: 160px; backdrop-filter: blur(10px); box-shadow: 0 4px 6px rgba(0,0,0,0.15);">
        <h3 style="font-size: 2.2rem; color: var(--accent-success); margin-bottom: 0.25rem; font-family: 'Fira Code', monospace;"><%= todaySolved %></h3>
        <p style="color: var(--text-muted); font-size: 0.9rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">Solved Today</p>
    </div>
    <div class="stat-card" style="background: var(--card-bg); border: 1px solid var(--border-color); padding: 1.25rem 2rem; border-radius: 12px; text-align: center; min-width: 160px; backdrop-filter: blur(10px); box-shadow: 0 4px 6px rgba(0,0,0,0.15);">
        <h3 style="font-size: 2.2rem; color: var(--accent-primary); margin-bottom: 0.25rem; font-family: 'Fira Code', monospace;"><%= totalSolved %></h3>
        <p style="color: var(--text-muted); font-size: 0.9rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">Total Solved</p>
    </div>
</div>

<form action="/solve" method="GET" class="solve-url-panel">
    <label for="dashboardProblemUrl">Start solving from URL</label>
    <div class="solve-url-row">
        <input
            type="url"
            id="dashboardProblemUrl"
            name="url"
            required
            placeholder="Paste LeetCode / NeetCode / other problem URL..."
        >
        <button type="submit" class="btn btn-solve">Solve</button>
    </div>
</form>

<div class="dashboard-buttons">
    <a href="/problems/easy" class="btn btn-success">Easy Problems</a>
    <a href="/problems/medium" class="btn btn-warning">Medium Problems</a>
    <a href="/problems/hard" class="btn btn-danger">Hard Problems</a>
    <a href="/problems/due" class="btn btn-purple">All Due Problems</a>
    <a href="/concepts/new" class="btn btn-turq">Add Concept</a> 
    <a href="/concepts" class="btn btn-pink">Due Concepts</a>
</div>

<%- include('partials/footer') %>

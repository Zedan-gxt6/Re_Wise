<%- include('partials/header') %>

<h1 style="text-align: center; margin-bottom: 2rem;">Welcome to Your DSA Planner Dashboard</h1>

<div class="dashboard-buttons">
    <a href="/new" class="btn btn-primary">+ Add New Problem</a>
    <a href="/problems/easy" class="btn btn-success">Easy Problems</a>
    <a href="/problems/medium" class="btn btn-warning">Medium Problems</a>
    <a href="/problems/hard" class="btn btn-danger">Hard Problems</a>
    <a href="/problems/due" class="btn btn-purple">All Due Problems</a>
    <button id="getHintsBtn" class="btn btn-info">Get Hints (AI)</button>
</div>

<!-- Hints Modal -->
<div id="hintsModal" class="modal">
    <div class="modal-content">
        <span class="close-modal">&times;</span>
        <h2 style="margin-bottom: 1rem;">AI Problem Hints</h2>
        <div class="form-group">
            <label for="problemDescription">Problem Description (e.g., Rotting Oranges, Leetcode)</label>
            <input type="text" id="problemDescription" placeholder="Enter problem name/description..." style="margin-bottom: 1rem;" />
        </div>
        <button id="generateHintsBtn" class="btn btn-primary" style="width: 100%; margin-bottom: 1rem;">Generate Hints</button>
        
        <div id="loadingHints" style="display: none; text-align: center; margin: 1.5rem 0;">
            <div class="spinner"></div>
            <p>Analyzing problem and generating progressive hints...</p>
        </div>

        <div id="hintsContainer" class="hints-container">
            <!-- Hints will be populated here -->
        </div>
    </div>
</div>

<script>
    const modal = document.getElementById("hintsModal");
    const getHintsBtn = document.getElementById("getHintsBtn");
    const closeBtn = document.querySelector(".close-modal");
    const generateBtn = document.getElementById("generateHintsBtn");
    const problemInput = document.getElementById("problemDescription");
    const hintsContainer = document.getElementById("hintsContainer");
    const loadingHints = document.getElementById("loadingHints");

    getHintsBtn.onclick = () => { modal.style.display = "block"; }
    closeBtn.onclick = () => { modal.style.display = "none"; }
    window.onclick = (e) => { if (e.target == modal) { modal.style.display = "none"; } }

    generateBtn.onclick = async () => {
        const desc = problemInput.value.trim();
        if(!desc) return alert("Please enter a problem description");

        hintsContainer.innerHTML = "";
        loadingHints.style.display = "block";
        generateBtn.disabled = true;

        try {
            const res = await fetch("/api/hints", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ problemDescription: desc })
            });
            const data = await res.json();

            if (data.error) {
                alert(data.error);
                return;
            }

            parseAndRenderHints(data.content);
        } catch (err) {
            alert("Error generating hints");
        } finally {
            loadingHints.style.display = "none";
            generateBtn.disabled = false;
        }
    };

    function parseAndRenderHints(text) {
        // Extract content between Start: and End.
        let startIndex = text.indexOf("Start:");
        let endIndex = text.indexOf("End.");
        
        if (startIndex === -1) startIndex = 0;
        else startIndex += 6;
        
        if (endIndex === -1) endIndex = text.length;

        const mainContent = text.substring(startIndex, endIndex).trim();
        
        const lines = mainContent.split('\n');
        const sections = [];
        let currentSection = null;

        // Regex to identify headings defined in prompt
        const headerRegex = /^(Hint \d+(?:,\d+)*.*?|Edge cases.*?|Time complexity.*?):?/i;

        for (let line of lines) {
            const match = line.match(headerRegex);
            if (match) {
                if (currentSection) {
                    sections.push(currentSection);
                }
                let title = line.substring(0, match[0].length).replace(/:$/, '').trim();
                let content = line.substring(match[0].length).trim() + '\n';
                currentSection = { title, content };
            } else {
                if (currentSection) {
                    currentSection.content += line + '\n';
                } else if(line.trim()) {
                    currentSection = { title: "Overview", content: line + '\n' };
                }
            }
        }
        if (currentSection) sections.push(currentSection);

        sections.forEach((sec) => {
            const details = document.createElement("details");
            details.className = "hint-details";
            
            const summary = document.createElement("summary");
            summary.textContent = sec.title;
            
            const contentDiv = document.createElement("div");
            contentDiv.className = "hint-content";
            
            // Basic formatting
            const escaped = sec.content
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;");
            
            // Format code blocks
            const formatted = escaped.replace(/```([\s\S]*?)```/g, '<pre><code>$1</code></pre>');
            contentDiv.innerHTML = formatted.replace(/\n/g, "<br>");
            
            details.appendChild(summary);
            details.appendChild(contentDiv);
            hintsContainer.appendChild(details);
        });
    }
</script>

<%- include('partials/footer') %>

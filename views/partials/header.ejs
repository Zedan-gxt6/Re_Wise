<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DSA Spaced Repetition</title>
    <!-- We link our CSS file from the public folder -->
    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <header>
        <nav class="navbar">
            <a href="/" class="brand-mark">
                <img src="/rewise-logo.svg" alt="" class="brand-logo">
                <span>Re_Wise</span>
            </a>

            <div class="nav-actions">
                <a href="/problems/filter">All Problems</a>
                <a href="/concepts/all">All Concepts</a>
                <a href="/profile/me">Profile</a>
                <a href="/notifications" class="notification-nav-link" aria-label="Notifications">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M18 16v-5a6 6 0 0 0-12 0v5l-2 2h16l-2-2Z"></path>
                        <path d="M9.5 20a2.5 2.5 0 0 0 5 0"></path>
                    </svg>
                    <% if (locals.unreadNotifications > 0) { %>
                        <span><%= locals.unreadNotifications %></span>
                    <% } %>
                </a>
                <form action="/logout" method="POST" class="logout-form">
                    <button type="submit">Logout</button>
                </form>
            </div>
        </nav>
    </header>
    <main class="container">

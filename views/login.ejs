<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Login – Re_Wise</title>
  <link rel="icon" type="image/svg+xml" href="/rewise-logo.svg">
  <link rel="stylesheet" href="/styles.css">
  <style>
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      margin: 0;
    }
    .card {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      padding: 2.5rem 2rem;
      border-radius: 12px;
      width: 100%;
      max-width: 360px;
      backdrop-filter: blur(10px);
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
    }
    .card > h2 {
      text-align: center;
      margin-bottom: 1.5rem;
      background: linear-gradient(to right, #3b82f6, #8b5cf6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      font-size: 1.80rem;
      font-weight: 600;
    }
    .form-group {
      margin-bottom: 1.25rem;
    }
    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 500;
      color: var(--text-muted);
      font-size: 0.9rem;
    }
    input[type="text"],
    input[type="password"] {
      width: 100%;
      padding: 0.75rem;
      background-color: rgba(0, 0, 0, 0.2);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      color: var(--text-main);
      font-size: 1rem;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
      box-sizing: border-box;
    }
    input:focus {
      outline: none;
      border-color: var(--accent-primary);
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
    }
    .card > p {
      margin-top: 1.5rem;
      text-align: center;
      color: var(--text-muted);
      font-size: 0.95rem;
    }
    .card > p a {
      color: var(--accent-info);
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s ease;
    }
    .card > p a:hover {
      color: var(--accent-primary);
      text-decoration: underline;
    }
    #msg {
      margin-top: 1rem;
      text-align: center;
      font-size: 0.9rem;
      color: var(--accent-danger);
    }
    .auth-divider {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 0.75rem;
      align-items: center;
      margin: 1.25rem 0;
      color: var(--text-muted);
      font-size: 0.82rem;
    }
    .auth-divider::before,
    .auth-divider::after {
      content: "";
      height: 1px;
      background: var(--border-color);
    }
    .btn-google {
      display: block;
      width: 100%;
      color: var(--text-main);
      background: rgba(2, 6, 23, 0.72);
      border: 1px solid var(--border-color);
      box-sizing: border-box;
    }
    .btn-google:hover {
      border-color: rgba(103, 232, 249, 0.45);
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="login-brand">
      <img src="/rewise-logo.svg" alt="Re_Wise logo">
      <h2>Re_Wise</h2>
      <p>Revise smarter. Learn together.</p>
    </div>
    <form id="loginForm">
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" placeholder="Enter username" required />
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="Enter password" required />
      </div>
      <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 0.5rem;">Log In</button>
    </form>
    <div class="auth-divider">or</div>
    <a id="googleLoginLink" href="/auth/google" class="btn btn-google">Continue with Google</a>
    <p>New here? <a href="/signup">Create an account</a></p>
    <div id="msg"></div>
  </div>

  <script>
    const form = document.getElementById('loginForm');
    const msg = document.getElementById('msg');
    const googleLoginLink = document.getElementById('googleLoginLink');
    const params = new URLSearchParams(window.location.search);
    const returnTo = params.get('returnTo');
    const errorMessage = params.get('error');

    if (returnTo) {
      googleLoginLink.href = `/auth/google?returnTo=${encodeURIComponent(returnTo)}`;
    }
    if (errorMessage) {
      msg.textContent = errorMessage === 'google_not_configured'
        ? 'Google login is not configured yet.'
        : 'Google login failed. Please try again.';
    }

    form.onsubmit = async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const res = await fetch('/api/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(data))
      });
      const json = await res.json();
      if (json.message) {
        msg.textContent = json.message;
        window.location.href = params.get('returnTo') || '/dashboard';
      } else {
        msg.textContent = json.error || 'Login failed';
      }
    };
  </script>
</body>
</html>
